  <folder name="Motivation" id="id-10fc0b07e32c48f687b65f08916fc601" type="motivation">
    <element xsi:type="archimate:Requirement" name="Authentication fraud not possible" id="id-06dd5a7d85834363a9333048c00fbd6a"/>
    <element xsi:type="archimate:Driver" name="Breach of Client information privacy laws (Compliance Risk)" id="id-3e47cf1535aa4bae942b985b82ffb5e2"/>
    <element xsi:type="archimate:Goal" name="Breach private data" id="id-29a35535eb694ec7ac76e28454634910"/>
    <element xsi:type="archimate:Driver" name="Client Card safety code generation uses public algorithm" id="id-80e13f75df064b2ba9bd20f48ca13bc0"/>
    <element xsi:type="archimate:Driver" name="Data breach (Information Risk)" id="id-4079bbbefb4c402298dd5f3724dbdc26"/>
    <element xsi:type="archimate:Outcome" name="Financial restitutions for theft" id="id-950b936ebcc94bcbb1892cc792634a21"/>
    <element xsi:type="archimate:Goal" name="Identity theft" id="id-023b36b8b729488fa5f3002c3043433a"/>
    <element xsi:type="archimate:Goal" name="Increase customer engagement and satisfaction" id="id-a55ae769837e4f34b80cc851b481c43e"/>
    <element xsi:type="archimate:Driver" name="Loss of Client trust (Reputation Risk)" id="id-eccd84fad88f4447aaf7f14f4152396d"/>
    <element xsi:type="archimate:Outcome" name="Loss of organizational reputation" id="id-141d7c4d02e6485da2d75b19b29ea259"/>
    <element xsi:type="archimate:Outcome" name="Loss of service credibility" id="id-6afbdb180a6d43b2af7f3b3dcd50c0e9"/>
    <element xsi:type="archimate:Driver" name="Lower Implementation costs (Financial Risk)" id="id-4cf9652256404544a38304e097380d71"/>
    <element xsi:type="archimate:Driver" name="Lower Maintenance costs (Financial Risk)" id="id-b71a12e3a87e4f09a3a11b3067f91685"/>
    <element xsi:type="archimate:Goal" name="Make advantageous purchases via Discount Service" id="id-9221d145b5364bed926820c7e543b764"/>
    <element xsi:type="archimate:Requirement" name="Masked document number in portal" id="id-f61c30f708b7440bb4208b49e13f345c"/>
    <element xsi:type="archimate:Driver" name="Misappropriation of Financial Assets (Financial Risk)" id="id-4848f82d895f449da679e4d9358ee879"/>
    <element xsi:type="archimate:Goal" name="Misappropriate financial resources" id="id-52e1cbb1012648fa859194ff6737d519"/>
    <element xsi:type="archimate:Driver" name="No need for internal capability assurance (People Risk)" id="id-b1497c69e9984489a350f2d91eb0ea90"/>
    <element xsi:type="archimate:Driver" name="Physical Cards can be replicated" id="id-559fa327bfe044379bab34459b150a08"/>
    <element xsi:type="archimate:Driver" name="Poorly implemented client card authentication" id="id-ed3b86ec7a7e4b1da5fde2b027a62f71"/>
    <element xsi:type="archimate:Driver" name="Portal allows Client Card access" id="id-4a1258c678324cf6a85b9b91ab36b46e"/>
    <element xsi:type="archimate:Requirement" name="Safety PIN for client access" id="id-b4bc5431e7ab4c52b6ba898939890591"/>
    <element xsi:type="archimate:Driver" name="Safety code generation can be manipulated" id="id-056501d347054d1d9cc65e6f86168007"/>
    <element xsi:type="archimate:Driver" name="Service Provider implementation failure (Third Party Risk)" id="id-9910290fa97a4adbbe7cb4ee29174f6d"/>
    <element xsi:type="archimate:Driver" name="Specialized Development Service (Third Party Risk)" id="id-ee2d690b978347bfb4eacfdb972392d7"/>
    <element xsi:type="archimate:Driver" name="Third Party Provider for Client Account Management Service (Third Party Risk)" id="id-425132f825234af4aa8f785ff9761a9b"/>
  </folder>
