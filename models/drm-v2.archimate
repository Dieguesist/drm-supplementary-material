  <folder name="Strategy" id="id-64051ff9556b44e2a5e281f1a91803c4" type="strategy">
    <element xsi:type="archimate:Capability" name="Strategic Direction Assessment" id="id-c8cdbfb469b649d39257c05dd15ea73c">
      <documentation>Indicates the organization's ability to reassess and adapt its direction.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="Digital Transformation Strategy" id="id-1b6132a02b0943cfac7d49087ff8d711">
      <documentation>If seen as a structured initiative, Course of Action. If seen as an ability of the organization, Capability.</documentation>
    </element>
  </folder>
  <folder name="Business" id="id-abd4a5007a0a4ab286103ae91ad8e416" type="business">
